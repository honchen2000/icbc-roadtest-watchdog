{
  "name": "icbc-roadtest-watchdog",
  "version": "0.0.1",
  "private": true,
  "description": "Free, open-source desktop app that watches for earlier ICBC road-test slots and notifies you (read-only, never books).",
  "keywords": [
    "icbc",
    "road-test",
    "appointment",
    "notifier",
    "electron",
    "british-columbia"
  ],
  "license": "MIT",
  "author": "honchen2000",
  "type": "module",
  "main": "./out/main/index.cjs",
  "homepage": "https://github.com/honchen2000/icbc-roadtest-watchdog#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/honchen2000/icbc-roadtest-watchdog.git"
  },
  "bugs": {
    "url": "https://github.com/honchen2000/icbc-roadtest-watchdog/issues"
  },
  "engines": {
    "node": ">=22.18"
  },
  "build": {
    "appId": "dev.honchen2000.icbc-roadtest-watchdog",
    "productName": "ICBC Road Test Watchdog",
    "files": ["out/**", "package.json"],
    "directories": { "buildResources": "build" },
    "mac": { "target": "dmg", "category": "public.app-category.utilities", "identity": null },
    "win": { "target": "nsis" },
    "linux": { "target": "AppImage", "category": "Utility" }
  },
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "pack": "electron-vite build && electron-builder --dir",
    "dist": "electron-vite build && electron-builder",
    "typecheck": "tsc --noEmit",
    "test": "node --test",
    "cli": "tsx src/cli.ts",
    "cli:node": "node src/cli.ts"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "electron": "^42.4.0",
    "electron-builder": "^26.15.3",
    "electron-vite": "^5.0.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vite": "^7.3.5"
  }
}
